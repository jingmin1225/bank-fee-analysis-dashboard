# ── Server ──────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (PostgreSQL) ────────────────
# Local:
DATABASE_URL=postgresql://bam_user:yourpassword@localhost:5432/bam_db
# Supabase example:
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# Railway example:
# DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/railway

# ── JWT ─────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_min_64_chars
JWT_EXPIRES_IN=7d

# ── File Storage ─────────────────────────
# Set STORAGE_DRIVER to "local" (default) or "s3"
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads

# AWS S3 (only if STORAGE_DRIVER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_S3_BUCKET=bam-documents

# ── CORS ────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── External API (Kyriba etc.) ──────────
EXTERNAL_API_TIMEOUT_MS=10000

# Kyriba OAuth2 / API proxy (used by /api/v1/kyriba/* routes)
KYRIBA_TOKEN_URL=
KYRIBA_BASE_URL=
KYRIBA_CLIENT_ID=
KYRIBA_CLIENT_SECRET=
KYRIBA_SCOPE=
